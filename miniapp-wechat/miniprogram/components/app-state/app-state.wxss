.state{text-align:center;padding:52rpx 30rpx}.state__symbol{width:128rpx;height:128rpx;margin:0 auto 22rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;background:#eff4ff;color:#0f766e}.state--error .state__symbol{background:#fff1f0;color:#b42318}.state--sessionExpired{width:560rpx;padding:42rpx 34rpx 34rpx;background:#fff;border-radius:28rpx;box-sizing:border-box;box-shadow:0 24rpx 70rpx rgba(15,23,42,.2)}.state--sessionExpired .state__symbol{width:92rpx;height:92rpx;background:#fff7ed;color:#f97316}.state__title{font-size:29rpx;font-weight:700;color:#172033}.state__description{margin-top:12rpx;font-size:22rpx;line-height:1.6;color:#64748b}.state__action{height:88rpx;line-height:88rpx;margin-top:26rpx;background:#0f766e;color:#fff;border-radius:12rpx;font-size:24rpx}.state--error .state__action{background:#fff;color:#0f766e;border:1rpx solid #0f766e}.state-mask{position:fixed;z-index:900;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(15,23,42,.42)}.spinner{width:34rpx;height:34rpx;border:5rpx solid rgba(15,118,110,.2);border-top-color:#0f766e;border-radius:50%;animation:spin .8s linear infinite}.error-symbol{font-size:48rpx;font-weight:800}.lock-symbol{position:relative;width:38rpx;height:31rpx;border:4rpx solid #f97316;border-radius:5rpx}.lock-symbol:before{content:'';position:absolute;left:7rpx;top:-24rpx;width:20rpx;height:23rpx;border:4rpx solid #f97316;border-bottom:0;border-radius:14rpx 14rpx 0 0}.empty-symbol{width:50rpx;height:38rpx;border:4rpx solid #94a3b8;border-radius:6rpx}.skeleton{display:grid;grid-template-columns:1fr 1fr;gap:14rpx;margin-bottom:28rpx}.skeleton view{height:80rpx;background:linear-gradient(90deg,#eef2f6,#f8fafc,#eef2f6);background-size:200% 100%;border-radius:12rpx;animation:shine 1.3s infinite}.state--loading .state__symbol{width:48rpx;height:48rpx;background:transparent}.state--loading .state__title{font-size:23rpx}@keyframes spin{to{transform:rotate(360deg)}}@keyframes shine{to{background-position:-200% 0}}
