<view class="{{state === 'sessionExpired' ? 'state-mask' : ''}}"><view class="state state--{{state}}"><view wx:if="{{state === 'loading'}}" class="skeleton"><view></view><view></view><view></view><view></view></view><view class="state__symbol"><view wx:if="{{state === 'loading'}}" class="spinner"></view><view wx:elif="{{state === 'error'}}" class="error-symbol">!</view><view wx:elif="{{state === 'sessionExpired'}}" class="lock-symbol"></view><view wx:else class="empty-symbol"></view></view><view class="state__title">{{title}}</view><view class="state__description">{{description}}</view><button wx:if="{{actionText}}" class="state__action" bindtap="action">{{actionText}}</button></view></view>
