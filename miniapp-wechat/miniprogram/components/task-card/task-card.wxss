.task{padding:26rpx;background:#fff;border:1rpx solid #e2e8f0;border-radius:20rpx;margin-bottom:18rpx;box-shadow:0 3rpx 10rpx rgba(15,23,42,.025)}.task__head{display:flex;justify-content:space-between;align-items:flex-start;gap:18rpx}.task__no{color:#64748b;font-size:19rpx;font-weight:600}.task__name{margin-top:5rpx;color:#172033;font-size:26rpx;font-weight:700}.task__data{display:grid;grid-template-columns:1fr 1fr;gap:22rpx;margin-top:22rpx}.task__data text{color:#64748b;font-size:20rpx}.task__data view view{margin-top:5rpx;color:#172033;font-size:22rpx;font-weight:500}.task__data .task__count{color:#0f766e}.task__data .task__count--danger{color:#b42318}.task__progress{height:8rpx;margin-top:20rpx;overflow:hidden;background:#e5eeff;border-radius:99rpx}.task__bar{height:100%;background:#0f766e}.task__bar--danger{background:#b42318}.task__alert{display:flex;align-items:center;gap:10rpx;margin-top:18rpx;padding:12rpx 14rpx;background:#fff1f0;border:1rpx solid #f5cbc7;border-radius:10rpx;color:#b42318;font-size:18rpx}.alert-triangle{width:22rpx;height:22rpx;display:flex;align-items:center;justify-content:center;border:2rpx solid #b42318;border-radius:50%;font-size:14rpx;font-weight:700}
