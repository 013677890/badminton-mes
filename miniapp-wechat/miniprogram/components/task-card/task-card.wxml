<view class="task"><view class="task__head"><view><view class="task__no">{{task.taskNo}}</view><view class="task__name">{{task.productName}}</view></view><status-chip text="{{task.abnormal ? '产线异常' : '运行中'}}" tone="{{task.abnormal ? 'danger' : 'success'}}"/></view><view class="task__data"><view><text>批次编号</text><view>{{task.batchNo}}</view></view><view><text>完工进度</text><view class="{{task.abnormal ? 'task__count--danger' : 'task__count'}}">{{task.finishQuantity}} / {{task.planQuantity}}</view></view></view><view class="task__progress"><view class="task__bar {{task.abnormal ? 'task__bar--danger' : ''}}" style="width: {{task.progress}}%"></view></view><view wx:if="{{task.abnormal}}" class="task__alert"><view class="alert-triangle">!</view><text>生产任务存在异常，请及时查看现场设备</text></view></view>
