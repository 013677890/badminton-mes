.metric{min-height:132rpx;padding:24rpx;background:#fff;border:1rpx solid #e2e8f0;border-radius:20rpx;box-sizing:border-box;box-shadow:0 3rpx 10rpx rgba(15,23,42,.025)}.metric__label{color:#64748b;font-size:22rpx}.metric__value{margin-top:12rpx;color:#172033;font-size:40rpx;line-height:1;font-weight:700;font-variant-numeric:tabular-nums}.metric--success .metric__value,.metric--primary .metric__value{color:#005c55}.metric--warning .metric__value{color:#f97316}.metric--danger .metric__value{color:#b42318}.metric__unit{margin-left:6rpx;color:#64748b;font-size:18rpx;font-weight:500}.metric__hint{margin-top:8rpx;color:#f97316;font-size:17rpx}
