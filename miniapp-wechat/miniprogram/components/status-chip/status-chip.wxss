.chip{display:inline-flex;align-items:center;gap:10rpx;padding:8rpx 16rpx;border-radius:999rpx;background:#f1f5f9;color:#475569;font-size:22rpx}.chip__dot{width:10rpx;height:10rpx;border-radius:50%;background:#94a3b8}.chip--success{background:#ecfdf5;color:#047857}.chip--success .chip__dot{background:#10b981}.chip--warning{background:#fff7ed;color:#c2410c}.chip--warning .chip__dot{background:#f97316}.chip--danger{background:#fff1f0;color:#b42318}.chip--danger .chip__dot{background:#b42318}
