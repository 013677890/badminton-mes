.mask{position:fixed;z-index:999;inset:0;display:flex;align-items:center;justify-content:center;padding:48rpx;background:rgba(15,23,42,.42);box-sizing:border-box}.dialog{width:100%;max-width:600rpx;padding:42rpx 36rpx 34rpx;background:#fff;border-radius:28rpx;box-sizing:border-box;box-shadow:0 24rpx 70rpx rgba(15,23,42,.2)}.dialog__mark{width:104rpx;height:104rpx;display:flex;align-items:center;justify-content:center;margin:0 auto;background:#eaf5f4;color:#0f766e;border-radius:50%}.dialog__mark--danger{background:#fff1f0;color:#b42318}.dialog__symbol{font-size:44rpx;font-weight:800}.dialog__title{margin-top:26rpx;text-align:center;color:#172033;font-size:34rpx;font-weight:700}.dialog__desc{margin-top:14rpx;text-align:center;color:#64748b;font-size:23rpx;line-height:1.65}.dialog__actions{display:flex;flex-direction:column;gap:16rpx;margin-top:32rpx}.dialog__actions button{width:100%;height:92rpx;line-height:92rpx;margin:0;border-radius:12rpx;font-size:26rpx;font-weight:600}.cancel{background:#f1f5f9;color:#475569}.confirm{background:#0f766e;color:#fff}.confirm--danger{background:#b42318}
