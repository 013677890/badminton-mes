<view wx:if="{{visible}}" class="mask" catchtouchmove="noop" bindtap="cancel"><view class="dialog" catchtap="noop"><view class="dialog__mark {{danger ? 'dialog__mark--danger' : ''}}"><view class="dialog__symbol">{{danger ? '!' : 'i'}}</view></view><view class="dialog__title">{{title}}</view><view class="dialog__desc">{{description}}</view><view class="dialog__actions"><button class="confirm {{danger ? 'confirm--danger' : ''}}" loading="{{loading}}" bindtap="confirm">{{confirmText}}</button><button class="cancel" bindtap="cancel">取消</button></view></view></view>
