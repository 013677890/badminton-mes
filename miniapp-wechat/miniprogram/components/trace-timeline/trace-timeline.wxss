.timeline{padding:6rpx 0}.timeline__item{position:relative;display:flex;gap:22rpx;padding-bottom:28rpx}.timeline__item:last-child{padding-bottom:0}.timeline__item:not(:last-child):after{content:'';position:absolute;left:9rpx;top:22rpx;bottom:0;width:2rpx;background:#d9f4ef}.timeline__dot{position:relative;z-index:1;width:20rpx;height:20rpx;flex:0 0 20rpx;margin-top:3rpx;background:#0f766e;border:6rpx solid #ccfbf1;border-radius:50%}.timeline__title{color:#334155;font-size:26rpx;font-weight:700}.timeline__time{margin-top:7rpx;color:#94a3b8;font-size:22rpx}
