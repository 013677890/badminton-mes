page{background:#f8fafc;color:#172033;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif;font-size:28rpx}button{box-sizing:border-box}button::after{border:0}.page{min-height:100vh;padding:32rpx 32rpx 56rpx;box-sizing:border-box}.page--compact{padding-top:20rpx}.eyebrow{color:#0f766e;font-size:23rpx;font-weight:700;letter-spacing:2rpx}.page-title{margin-top:10rpx;color:#172033;font-size:48rpx;line-height:1.15;font-weight:800}.section-title{font-size:31rpx;font-weight:800;color:#172033}.muted{color:#64748b;font-size:24rpx}.card{background:#fff;border:1rpx solid #e8edf2;border-radius:24rpx;padding:28rpx;margin-bottom:22rpx;box-shadow:0 10rpx 30rpx rgba(15,23,42,.035)}.primary{background:#0f766e;color:#fff;border-radius:14rpx}.primary[disabled]{background:#94a3b8;color:#fff}.ghost{background:#ecfdfb;color:#0f766e;border-radius:14rpx}.danger{background:#fff1f0;color:#b42318;border-radius:14rpx}.input{height:96rpx;padding:0 24rpx;margin-bottom:18rpx;background:#f8fafc;border:1rpx solid #e2e8f0;border-radius:14rpx;box-sizing:border-box}.divider{height:1rpx;background:#edf2f7;margin:24rpx 0}.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:18rpx}.tip{padding:18rpx 20rpx;background:#fff7ed;color:#9a3412;border-radius:14rpx;font-size:24rpx;line-height:1.55}.safe-bottom{padding-bottom:env(safe-area-inset-bottom)}

/* Custom navigation bars must reserve the status-bar/notch area. */
.page-top,.top-bar,.brand-bar,.profile-top{height:calc(44px + 88rpx)!important;padding:44px 24rpx 0!important;align-items:center!important;box-sizing:border-box!important}.page-top,.brand-bar{height:calc(44px + 96rpx)!important}.page-top{gap:14rpx;padding-right:190rpx!important}.page-top .refresh-icon,.page-top .refresh-touch{margin-left:auto!important;margin-top:0!important;margin-bottom:0!important;flex:0 0 64rpx}.title-icon{width:30rpx;height:30rpx;flex:0 0 30rpx}
