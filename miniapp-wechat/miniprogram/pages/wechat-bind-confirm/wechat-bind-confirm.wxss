.confirm-page{min-height:100vh;background:#f8fafc;color:#172033}.top-bar{height:calc(44px + 88rpx);display:flex;align-items:center;justify-content:space-between;padding:44px 24rpx 0;background:#fff;border-bottom:1rpx solid #e2e8f0;box-sizing:border-box;font-size:29rpx;font-weight:700}.placeholder{width:72rpx}.confirm-content{padding:70rpx 28rpx}.state-card,.result-card{padding:38rpx 30rpx;background:#fff;border:1rpx solid #e2e8f0;border-radius:24rpx;text-align:center}.wechat-logo{position:relative;width:92rpx;height:92rpx;margin:0 auto;background:#eaf5f4;border-radius:24rpx}.wechat-logo view{position:absolute;width:40rpx;height:31rpx;border:3rpx solid #0f766e;border-radius:50%}.wechat-logo view:first-child{left:16rpx;top:20rpx}.wechat-logo view:last-child{right:13rpx;bottom:17rpx}.result-icon{width:88rpx;height:88rpx;line-height:88rpx;margin:0 auto;border-radius:50%;font-size:42rpx;font-weight:700}.result-icon--success{background:#eef9f1;color:#15803d}.result-icon--error{background:#fff1f0;color:#b42318}.result-title{margin-top:24rpx;font-size:34rpx;font-weight:700}.result-desc{margin-top:12rpx;color:#64748b;font-size:22rpx;line-height:1.65}.account-box{margin-top:30rpx;padding:10rpx 24rpx;background:#f8fafc;border:1rpx solid #e2e8f0;border-radius:16rpx;text-align:left}.account-box>view{display:flex;justify-content:space-between;padding:18rpx 0;border-bottom:1rpx solid #e2e8f0}.account-box>view:last-child{border-bottom:0}.account-box text{color:#64748b;font-size:21rpx}.account-box strong{font-size:23rpx}.result-card button{height:88rpx;line-height:88rpx;margin-top:28rpx;background:#0f766e;color:#fff;border-radius:12rpx;font-size:25rpx;font-weight:700}.result-card button[disabled]{background:#94a3b8}.security-tip{margin-top:18rpx;color:#94a3b8;font-size:18rpx;line-height:1.6}.form-error{margin-top:16rpx;color:#b42318;font-size:21rpx}
.account-box .account-value{color:#172033;font-size:23rpx;font-weight:700}
