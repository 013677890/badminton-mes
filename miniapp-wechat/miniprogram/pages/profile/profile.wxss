.profile-page{min-height:100vh;background:#f8fafc;color:#172033}.profile-top{height:96rpx;display:flex;align-items:center;justify-content:space-between;padding:0 24rpx;background:#fff;border-bottom:1rpx solid #e2e8f0;box-sizing:border-box;font-size:30rpx;font-weight:700}.top-icon{position:relative;width:64rpx;height:64rpx}.top-icon--settings:before{content:'';position:absolute;left:20rpx;top:20rpx;width:20rpx;height:20rpx;border:3rpx solid #172033;border-radius:50%;box-shadow:0 -9rpx 0 -6rpx #172033,0 9rpx 0 -6rpx #172033,9rpx 0 0 -6rpx #172033,-9rpx 0 0 -6rpx #172033}.top-icon--notice:before{content:'';position:absolute;left:22rpx;top:17rpx;width:18rpx;height:24rpx;border:3rpx solid #172033;border-top-left-radius:12rpx;border-top-right-radius:12rpx}.top-icon--notice:after{content:'';position:absolute;left:19rpx;top:42rpx;width:26rpx;height:3rpx;background:#172033}.profile-content{padding:24rpx 28rpx 160rpx}.user-card,.settings-card{background:#fff;border:1rpx solid #e2e8f0;border-radius:24rpx;box-shadow:0 4rpx 12rpx rgba(15,23,42,.025)}.user-card{padding:26rpx}.user-head{display:flex;align-items:flex-start}.avatar{position:relative;width:88rpx;height:88rpx;flex:0 0 88rpx;background:#eaf5f4;border:1rpx solid #b8d9d5;border-radius:50%}.avatar-head{position:absolute;left:31rpx;top:22rpx;width:22rpx;height:22rpx;border:3rpx solid #0f766e;border-radius:50%}.avatar-body{position:absolute;left:23rpx;top:49rpx;width:38rpx;height:22rpx;border:3rpx solid #0f766e;border-radius:24rpx 24rpx 12rpx 12rpx}.user-main{flex:1;min-width:0;margin-left:20rpx}.name-line{display:flex;align-items:center;gap:10rpx;flex-wrap:wrap}.profile-name{font-size:31rpx;font-weight:700}.role-badge{padding:6rpx 12rpx;background:#0f766e;color:#fff;border-radius:999rpx;font-size:18rpx;font-weight:600}.profile-no{margin-top:10rpx;color:#64748b;font-size:22rpx}.bind-badge{display:flex;align-items:center;gap:6rpx;margin-left:8rpx;padding:8rpx 10rpx;background:#eef9f1;color:#15803d;border-radius:10rpx;white-space:nowrap;font-size:18rpx}.bind-dot{width:11rpx;height:11rpx;border:2rpx solid #15803d;border-radius:50%}.org-row{display:grid;grid-template-columns:1fr 1fr;gap:18rpx;margin-top:26rpx;padding-top:22rpx;border-top:1rpx solid #e2e8f0}.org-row>view{display:flex;align-items:center;gap:10rpx;color:#64748b;font-size:21rpx}.org-icon{width:22rpx;height:18rpx;border:2rpx solid #64748b}.org-icon--line{border-radius:50%}.settings-card{margin-top:20rpx;overflow:hidden}.setting-row{height:92rpx;display:flex;align-items:center;padding:0 24rpx;font-size:25rpx}.setting-symbol{width:28rpx;height:28rpx;margin-right:18rpx;color:#0f766e}.setting-symbol--shield{border:3rpx solid #0f766e;border-radius:12rpx 12rpx 14rpx 14rpx}.setting-symbol--info{display:flex;align-items:center;justify-content:center;border:3rpx solid #0f766e;border-radius:50%;font-size:18rpx;font-weight:700}.setting-row text{flex:1}.chevron{width:14rpx;height:14rpx;border-right:2rpx solid #94a3b8;border-top:2rpx solid #94a3b8;transform:rotate(45deg)}.setting-divider{height:1rpx;margin:0 24rpx;background:#e2e8f0}.mock-entry{margin-top:18rpx;color:#94a3b8;text-align:center;font-size:19rpx}.profile-action{height:88rpx;line-height:88rpx;margin-top:32rpx;background:#fff;color:#172033;border:1rpx solid #e2e8f0;border-radius:12rpx;font-size:24rpx}.profile-action--danger{margin-top:14rpx;color:#b42318;border-color:#dc6b63}.unbind-tip{margin-top:14rpx;color:#64748b;text-align:center;font-size:20rpx}.version{margin-top:54rpx;color:#c1cad5;text-align:center;font-size:17rpx;line-height:1.9;letter-spacing:3rpx}.version text{letter-spacing:0}.logout-icon,.unlink-icon{display:inline-block;width:20rpx;height:20rpx;margin-right:12rpx;vertical-align:-3rpx;border:2rpx solid currentColor}.unlink-icon{border-radius:50%;transform:rotate(-30deg)}

.org-row image{width:25rpx;height:25rpx}.basic-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rpx;margin:24rpx -26rpx -26rpx;background:#e2e8f0;border-radius:0 0 24rpx 24rpx;overflow:hidden}.basic-grid>view{padding:20rpx 26rpx;background:#fbfdff}.basic-grid text{display:block;color:#64748b;font-size:18rpx}.basic-grid .basic-value{max-width:260rpx;margin-top:8rpx;overflow:hidden;color:#172033;font-size:21rpx;font-weight:600;text-overflow:ellipsis;white-space:nowrap}.setting-row{height:112rpx}.setting-row image{width:34rpx;height:34rpx;margin-right:18rpx}.setting-copy{flex:1}.setting-copy text,.setting-copy small{display:block}.setting-copy text{font-size:24rpx;font-weight:600}.setting-copy small{margin-top:6rpx;color:#64748b;font-size:18rpx}.profile-action{margin-top:24rpx}
.profile-action .action-icon{display:inline-block;width:30rpx;height:30rpx;margin-right:14rpx;vertical-align:-7rpx}.logout-icon,.unlink-icon{display:none}
.bind-badge--warning{background:#fff7ed;color:#c2410c}.bind-badge--warning .bind-dot{border-color:#c2410c}.admin-card{display:flex;align-items:center;margin-top:20rpx;padding:22rpx 24rpx;background:linear-gradient(135deg,#0f766e,#115e59);color:#fff;border-radius:22rpx;box-shadow:0 12rpx 28rpx rgba(15,118,110,.18)}.admin-icon{width:68rpx;height:68rpx;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.14);border-radius:18rpx}.admin-icon image{width:38rpx;height:38rpx;filter:brightness(0) invert(1)}.admin-copy{flex:1;margin-left:18rpx}.admin-copy text,.admin-copy small{display:block}.admin-copy text{font-size:25rpx;font-weight:700}.admin-copy small{margin-top:6rpx;color:rgba(255,255,255,.75);font-size:18rpx}.admin-badge{margin-right:16rpx;padding:6rpx 10rpx;background:rgba(255,255,255,.14);border:1rpx solid rgba(255,255,255,.2);border-radius:999rpx;font-size:16rpx}.admin-card .chevron{border-color:#fff}
