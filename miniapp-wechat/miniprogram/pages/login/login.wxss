.login-page{position:relative;min-height:100vh;overflow:hidden;background:#f8fafc;color:#172033}.brand-bar{height:112rpx;display:flex;align-items:flex-end;justify-content:center;gap:12rpx;padding-bottom:20rpx;background:#fff;box-sizing:border-box;color:#0f766e;font-size:28rpx;font-weight:700}.factory-icon{position:relative;width:24rpx;height:20rpx;border:3rpx solid #0f766e;border-top:0}.factory-icon:before{content:'';position:absolute;left:2rpx;top:-10rpx;width:4rpx;height:10rpx;background:#0f766e;box-shadow:8rpx 4rpx 0 #0f766e,16rpx 0 0 #0f766e}.login-main{min-height:calc(100vh - 112rpx);display:flex;flex-direction:column;padding:56rpx 28rpx calc(38rpx + env(safe-area-inset-bottom));box-sizing:border-box}.hero{text-align:center}.brand-icon{position:relative;width:96rpx;height:96rpx;margin:0 auto;background:#eef7f6;border:1rpx solid #d5e9e7;border-radius:22rpx}.racket-head{position:absolute;left:27rpx;top:27rpx;width:25rpx;height:29rpx;border:4rpx solid #0f766e;border-radius:50%;transform:rotate(-42deg)}.racket-handle{position:absolute;left:51rpx;top:53rpx;width:28rpx;height:4rpx;background:#0f766e;transform:rotate(45deg)}.shuttle{position:absolute;right:19rpx;top:25rpx;border-left:12rpx solid transparent;border-right:12rpx solid transparent;border-top:19rpx solid #0f766e;transform:rotate(35deg)}.title{margin-top:28rpx;font-size:36rpx;font-weight:700}.subtitle{margin-top:10rpx;color:#64748b;font-size:23rpx}.capability-card{margin-top:46rpx;padding:30rpx 26rpx;background:#fff;border:1rpx solid #e2e8f0;border-radius:24rpx;box-shadow:0 8rpx 20rpx rgba(15,23,42,.035)}.capability{display:flex;align-items:flex-start;gap:20rpx;margin-bottom:30rpx;text-align:left}.capability:last-child{margin-bottom:0}.cap-icon{position:relative;width:72rpx;height:72rpx;flex:0 0 72rpx;background:#f8fafc;border:1rpx solid #edf1f5;border-radius:12rpx}.dashboard-icon{display:grid;grid-template-columns:repeat(2,12rpx);grid-template-rows:repeat(2,12rpx);gap:6rpx;padding:19rpx;box-sizing:border-box}.dashboard-icon view{border:2rpx solid #0f766e}.analysis-icon{display:flex;align-items:flex-end;justify-content:center;gap:5rpx;padding:18rpx;box-sizing:border-box}.analysis-icon view{width:8rpx;background:#0f766e}.analysis-icon view:nth-child(1){height:18rpx}.analysis-icon view:nth-child(2){height:30rpx}.analysis-icon view:nth-child(3){height:23rpx}.trace-icon:before,.trace-icon:after,.trace-icon view{content:'';position:absolute;border:2rpx solid #0f766e}.trace-icon:before{left:19rpx;top:18rpx;width:12rpx;height:12rpx}.trace-icon:after{right:18rpx;bottom:18rpx;width:12rpx;height:12rpx}.trace-icon view{left:27rpx;top:27rpx;width:16rpx;height:16rpx;border-style:dashed}.cap-title{font-size:25rpx;font-weight:700}.cap-desc{margin-top:6rpx;color:#64748b;font-size:20rpx;line-height:1.55}.login-actions{margin-top:auto;padding-top:36rpx}.wechat-button,.account-button{height:92rpx;line-height:92rpx;border-radius:10rpx;font-size:24rpx;font-weight:600}.wechat-button{background:#0f766e;color:#fff}.wechat-button[disabled]{background:#94a3b8;color:#fff}.account-button{margin-top:16rpx;background:#fff;color:#0f766e;border:1rpx solid #0f766e}.wechat-icon,.account-icon{position:relative;display:inline-block;width:28rpx;height:28rpx;margin-right:10rpx;vertical-align:-6rpx}.wechat-icon view{position:absolute;width:18rpx;height:15rpx;border:2rpx solid currentColor;border-radius:50%}.wechat-icon view:first-child{left:0;top:1rpx}.wechat-icon view:last-child{right:0;bottom:0}.account-icon{border:2rpx solid currentColor;border-radius:4rpx;box-sizing:border-box}.account-icon view{position:absolute;left:7rpx;top:5rpx;width:9rpx;height:9rpx;border:2rpx solid currentColor;border-radius:50%}.login-error{margin-top:12rpx;color:#b42318;text-align:center;font-size:20rpx}.agreement{margin-top:20rpx;color:#64748b;text-align:center;font-size:18rpx}.agreement text{color:#172033;text-decoration:underline}.industrial-line{position:absolute;left:0;right:0;bottom:0;height:7rpx;opacity:.18;background:repeating-linear-gradient(45deg,#0f766e,#0f766e 3rpx,transparent 3rpx,transparent 14rpx)}
