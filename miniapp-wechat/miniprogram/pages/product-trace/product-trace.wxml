<view class="page"><view class="card"><input placeholder="输入批次码" value="{{batchCode}}" bindinput="input"/><button class="primary" bindtap="scan">扫码查询</button></view><view wx:if="{{trace.task}}" class="card"><view class="title">{{trace.task.taskNo}}</view><view>{{trace.task.productName}} · {{trace.task.batchNo}}</view><view class="muted">数据状态：{{trace.dataCompleteness}}</view></view><view wx:for="{{trace.processHistories}}" wx:key="operateTime" class="card"><view>{{item.processName}}</view><view class="muted">{{item.operateTime}}</view></view></view>
