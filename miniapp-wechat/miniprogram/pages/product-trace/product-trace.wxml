<!-- 批次码输入和扫码共用同一查询状态；只有存在工单时才显示任务摘要。 -->
<view class="trace-page">
  <view class="page-top">
    <image class="title-icon" src="/assets/icons/factory.svg" mode="aspectFit"/>
    <text>产品追溯</text>
    <view class="refresh-touch" bindtap="clear"><image src="/assets/icons/refresh.svg" mode="aspectFit"/></view>
  </view>
  <view class="trace-content">
    <view class="search-card">
      <view class="field-label">批次码</view>
      <view class="search-input"><input value="{{batchCode}}" maxlength="64" placeholder="请输入或扫描批次码" confirm-type="search" bindinput="input" bindconfirm="query"/><view wx:if="{{batchCode}}" class="clear" bindtap="clear">×</view></view>
      <button class="query-button" loading="{{loading}}" disabled="{{loading}}" bindtap="query"><image src="/assets/icons/search.svg" mode="aspectFit"/>查询</button>
      <button class="scan-button" disabled="{{loading}}" bindtap="scan"><image src="/assets/icons/qr-scan.svg" mode="aspectFit"/>扫码查询</button>
      <view wx:if="{{error && state === 'idle'}}" class="form-error">{{error}}</view>
    </view>
    <view wx:if="{{state === 'loading'}}" class="state-card"><app-state state="loading" title="数据加载中..." description="正在汇总产品履历"/></view>
    <view wx:elif="{{state === 'sessionExpired'}}"><app-state state="sessionExpired" title="登录状态已失效" description="为了账号安全，请重新登录" actionText="重新登录" bind:action="loginAgain"/></view>
    <view wx:elif="{{state === 'error'}}" class="state-card"><app-state state="error" title="查询失败" description="{{error}}" actionText="重试" bind:action="retry"/></view>
    <view wx:elif="{{state === 'empty'}}" class="state-card"><app-state state="empty" title="没有匹配记录" description="请确认批次码是否正确"/></view>
    <block wx:elif="{{state === 'ready'}}">
      <view class="card task-summary"><view class="summary-head"><view><view class="muted">生产任务</view><view class="task-no">{{trace.task.taskNo}}</view></view><status-chip text="{{trace.dataCompleteness}}" tone="{{trace.dataCompleteness === '完整' ? 'success' : 'warning'}}"/></view><view class="product-name">{{trace.task.productName}}</view><view class="muted">批次 {{trace.task.batchNo}}</view></view>
      <view class="card"><view class="section-title">工序时间轴</view><trace-timeline items="{{trace.processHistories}}"/></view>
      <view class="card" wx:if="{{trace.workReports.length}}"><view class="section-title">报工记录</view><view wx:for="{{trace.workReports}}" wx:key="reportNo" class="record"><view><view class="record-title">{{item.reportNo}}</view><view class="muted">{{item.reportTime}}</view></view><view class="record-number"><text>{{item.netGoodQuantity}}</text> 良品<br/><text class="bad">{{item.netDefectQuantity}}</text> 不良</view></view></view>
    </block>
    <block wx:else>
      <view class="section-head"><text>最近查询</text><view bindtap="clearHistory">清空历史</view></view>
      <view class="history-list">
        <view wx:for="{{history}}" wx:key="batchCode" class="history-item" data-code="{{item.batchCode}}" bindtap="useHistory"><view class="history-icon"><image src="/assets/icons/inventory.svg" mode="aspectFit"/></view><view class="history-main"><view><text>{{item.batchCode}}</text><small>{{item.time}}</small></view><view><text>{{item.productName}}</text><small>{{item.date}}</small></view></view></view>
        <view wx:if="{{!history.length}}" class="history-empty">暂无最近查询记录</view>
      </view>
      <view class="ability-card"><view class="section-title">追溯能力</view><view class="ability-grid"><view><image src="/assets/icons/process.svg" mode="aspectFit"/><text>工序记录</text></view><view><image src="/assets/icons/assignment.svg" mode="aspectFit"/><text>报工记录</text></view><view><image src="/assets/icons/repair.svg" mode="aspectFit"/><text>维修记录</text></view></view><view class="ability-tip">全流程数字化链路监控，确保每一批次品质可溯</view></view>
    </block>
  </view>
</view>
