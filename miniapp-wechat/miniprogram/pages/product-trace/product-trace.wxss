.trace-page{min-height:100vh;background:#f8fafc;color:#172033}.page-top{height:112rpx;display:flex;align-items:flex-end;gap:14rpx;padding:0 28rpx 20rpx;background:#fff;border-bottom:1rpx solid #e2e8f0;box-sizing:border-box;font-size:29rpx;font-weight:700}.factory-icon{width:25rpx;height:21rpx;border:3rpx solid #0f766e;border-top:0}.refresh-icon{position:relative;width:64rpx;height:64rpx;margin:-10rpx -12rpx -12rpx auto}.refresh-icon:before{content:'';position:absolute;left:19rpx;top:17rpx;width:24rpx;height:24rpx;border:3rpx solid #64748b;border-left-color:transparent;border-radius:50%}.trace-content{padding:26rpx 28rpx 150rpx}.search-card,.ability-card,.history-item,.card{background:#fff;border:1rpx solid #e2e8f0;border-radius:20rpx}.search-card{padding:28rpx}.field-label{margin-bottom:12rpx;font-size:23rpx;font-weight:600}.search-input{height:92rpx;display:flex;align-items:center;padding:0 22rpx;background:#f8fafc;border:1rpx solid #dbe3eb;border-radius:13rpx}.search-input input{flex:1;height:100%;font-size:24rpx}.clear{min-width:60rpx;text-align:right;color:#94a3b8;font-size:34rpx}.query-button,.scan-button{height:92rpx;line-height:92rpx;margin-top:18rpx;border-radius:12rpx;font-size:25rpx;font-weight:600}.query-button{background:#0f766e;color:#fff}.scan-button{background:#fff;color:#0f766e;border:1rpx solid #0f766e}.search-icon,.scan-icon{display:inline-block;width:20rpx;height:20rpx;margin-right:12rpx;vertical-align:-3rpx;border:3rpx solid currentColor;border-radius:50%}.scan-icon{border-radius:2rpx}.form-error{margin-top:14rpx;color:#b42318;font-size:21rpx}.section-head{display:flex;justify-content:space-between;margin:30rpx 4rpx 16rpx;font-size:25rpx;font-weight:700}.section-head view{color:#0f766e;font-size:20rpx;font-weight:500}.history-item{display:flex;align-items:center;gap:20rpx;margin-bottom:14rpx;padding:22rpx}.box-icon{width:56rpx;height:56rpx;flex:0 0 56rpx;background:#f8fafc;border:2rpx solid #0f766e;border-radius:10rpx}.history-main{flex:1}.history-main>view{display:flex;justify-content:space-between}.history-main>view:first-child text{font-size:22rpx;font-weight:700}.history-main>view:last-child{margin-top:8rpx;color:#64748b;font-size:19rpx}.history-main small{color:#64748b;font-size:17rpx}.history-empty{padding:30rpx;color:#94a3b8;text-align:center}.ability-card{margin-top:24rpx;padding:28rpx}.section-title{font-size:25rpx;font-weight:700}.ability-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx;margin-top:22rpx}.ability-grid>view{height:126rpx;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#f8fafc;border:1rpx solid #e2e8f0;border-radius:14rpx;font-size:19rpx}.ability-icon{width:34rpx;height:34rpx;margin-bottom:12rpx;border:3rpx solid #0f766e;border-radius:5rpx}.ability-icon--report{border-radius:50%}.ability-icon--repair{transform:rotate(45deg)}.ability-tip{margin-top:20rpx;color:#64748b;text-align:center;font-size:17rpx}.card{margin-top:20rpx;padding:26rpx}.task-summary{background:#fff}.summary-head{display:flex;justify-content:space-between}.task-no{margin-top:8rpx;font-size:30rpx;font-weight:700}.product-name{margin-top:22rpx;font-size:25rpx}.muted{color:#64748b;font-size:20rpx}.record{display:flex;justify-content:space-between;padding:20rpx 0;border-top:1rpx solid #e2e8f0}.record-title{font-size:22rpx;font-weight:600}.record-number{text-align:right;color:#64748b;font-size:18rpx}.record-number text{color:#15803d;font-size:24rpx;font-weight:700}.record-number .bad{color:#b42318}.state-card{margin-top:24rpx;background:#fff;border:1rpx solid #e2e8f0;border-radius:20rpx}

.title-icon{width:30rpx;height:30rpx}.refresh-touch{width:64rpx;height:64rpx;display:flex;align-items:center;justify-content:center;margin:-10rpx -12rpx -12rpx auto}.refresh-touch image{width:30rpx;height:30rpx}.query-button image,.scan-button image{display:inline-block;width:28rpx;height:28rpx;margin-right:12rpx;vertical-align:-7rpx}.history-icon{width:58rpx;height:58rpx;display:flex;align-items:center;justify-content:center;flex:0 0 58rpx;background:#f1f7f7;border-radius:10rpx}.history-icon image{width:34rpx;height:34rpx}.ability-grid image{width:42rpx;height:42rpx;margin-bottom:12rpx}.search-icon,.scan-icon,.box-icon,.ability-icon{display:none}
