.assignment-page{min-height:100vh;background:#f8fafc;color:#172033}.top-bar{height:calc(44px + 88rpx);display:flex;align-items:center;justify-content:space-between;padding:44px 24rpx 0;background:#fff;border-bottom:1rpx solid #e2e8f0;box-sizing:border-box;font-size:29rpx;font-weight:700}.back,.placeholder{width:72rpx;height:58rpx}.back{display:flex;align-items:center}.back view{width:18rpx;height:18rpx;margin-left:14rpx;border-left:3rpx solid #172033;border-bottom:3rpx solid #172033;transform:rotate(45deg)}.assignment-content{padding:24rpx 28rpx 64rpx}.page-state{padding:64rpx 24rpx;background:#fff;border:1rpx solid #e2e8f0;border-radius:22rpx;color:#64748b;text-align:center}.page-state button{width:200rpx;margin-top:20rpx;background:#0f766e;color:#fff}.user-card{display:flex;align-items:center;padding:24rpx;background:linear-gradient(135deg,#fff,#f4fbfa);border:1rpx solid #cfe3e1;border-radius:22rpx}.avatar{width:78rpx;height:78rpx;line-height:78rpx;background:#0f766e;color:#fff;border-radius:50%;text-align:center;font-size:30rpx;font-weight:700}.user-copy{flex:1;margin-left:18rpx}.user-copy text,.user-copy small{display:block}.user-copy text{font-size:27rpx;font-weight:700}.user-copy small{margin-top:7rpx;color:#64748b;font-size:20rpx}.binding-chip{padding:7rpx 11rpx;background:#fff7ed;color:#c2410c;border-radius:999rpx;font-size:17rpx}.binding-chip.bound{background:#eef9f1;color:#15803d}.admin-notice{display:flex;align-items:center;margin-top:16rpx;padding:18rpx 20rpx;background:#fff7ed;border:1rpx solid #fed7aa;border-radius:16rpx}.admin-notice image{width:36rpx;height:36rpx;margin-right:14rpx}.admin-notice text,.admin-notice small{display:block}.admin-notice text{color:#9a3412;font-size:22rpx;font-weight:700}.admin-notice small{margin-top:5rpx;color:#c2410c;font-size:18rpx;line-height:1.45}.form-card{margin-top:18rpx;padding:24rpx;background:#fff;border:1rpx solid #e2e8f0;border-radius:22rpx}.section-head{display:flex;align-items:center;justify-content:space-be