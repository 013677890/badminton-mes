<!-- 指标和在制任务均直接展示后端聚合快照，空数组时保留看板骨架。 -->
<view class="dashboard-page">
  <view class="page-top"><image class="title-icon" src="/assets/tabbar/dashboard-selected.png" mode="aspectFit"/><text>实时生产看板</text><view class="refresh-touch" bindtap="retry"><image src="/assets/icons/refresh.svg" mode="aspectFit"/></view></view>
  <view class="dashboard-content">
    <view class="meta-row"><view><view class="workshop">{{userWorkshop || '羽毛球一车间'}} · {{userLine || '1 号产线'}}</view><view class="live"><view class="live-dot"></view>{{lastRefreshTime ? '数据实时更新 · ' + lastRefreshTime : connectionText}}</view></view><view class="filter-icon"></view></view>
    <view wx:if="{{state === 'loading' && !tasks.length}}" class="state-card"><app-state state="loading" title="数据加载中..." description="正在获取最新生产现场数据"/></view>
    <view wx:elif="{{state === 'sessionExpired'}}"><app-state state="sessionExpired" title="登录状态已失效" description="为了账号安全，请重新登录" actionText="重新登录" bind:action="loginAgain"/></view>
    <view wx:elif="{{state === 'error'}}" class="state-card"><app-state state="error" title="数据加载失败" description="{{error}}" actionText="重新加载" bind:action="retry"/></view>
    <view wx:elif="{{state === 'empty'}}" class="state-card"><app-state state="empty" title="暂无生产数据" description="当前车间没有可展示的生产任务" actionText="刷新" bind:action="retry"/></view>
    <block wx:else>
      <view class="metric-grid"><metric-card label="计划量" value="{{overview.planQuantity}}" unit="件" tone="neutral"/><metric-card label="完成量" value="{{overview.goodQuantity}}" unit="件" tone="primary"/><metric-card label="不良量" value="{{overview.defectQuantity}}" unit="件" tone="warning"/><metric-card label="异常数" value="{{overview.openAndonCount}}" unit="项" tone="danger"/></view>
      <view class="progress-card"><view class="progress-head"><view><view class="trend-icon"></view><text>总体进度</text></view><text>{{overallProgress}}%</text></view><view class="overall-track"><view class="overall-bar" style="width: {{overallProgress}}%"></view></view><view class="progress-foot"><text>开始时间: 08:00</text><text>预计结束: 18:30</text></view></view>
      <view class="section-row"><view><image class="task-list-image" src="/assets/icons/task-list.svg" mode="aspectFit"/><text>在制任务</text></view><text>共 {{tasks.length}} 条任务</text></view>
      <task-card wx:for="{{tasks}}" wx:key="taskId" task="{{item}}"/>
    </block>
  </view>
</view>
