.dashboard-page{min-height:100vh;background:#f8fafc;color:#172033}.page-top{height:112rpx;display:flex;align-items:flex-end;gap:14rpx;padding:0 28rpx 20rpx;background:#fff;border-bottom:1rpx solid #e2e8f0;box-sizing:border-box;font-size:29rpx;font-weight:700}.factory-icon{width:25rpx;height:21rpx;border:3rpx solid #0f766e;border-top:0}.refresh-touch{width:64rpx;height:64rpx;display:flex;align-items:center;justify-content:center;margin:-10rpx -12rpx -12rpx auto}.refresh-touch image{width:30rpx;height:30rpx}.dashboard-content{padding:26rpx 28rpx 150rpx}.meta-row{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:22rpx}.workshop{font-size:22rpx;font-weight:500}.live{display:flex;align-items:center;gap:8rpx;margin-top:7rpx;color:#64748b;font-size:18rpx}.live-dot{width:12rpx;height:12rpx;background:#15803d;border-radius:50%;animation:pulse 2s infinite}.filter-icon{width:25rpx;height:25rpx;border-left:3rpx solid #64748b;border-right:3rpx solid #64748b}.metric-grid{display:grid;grid-template-columns:1fr 1fr;gap:18rpx}.progress-card{margin-top:22rpx;padding:26rpx;background:#fff;border:1rpx solid #e2e8f0;border-radius:20rpx}.progress-head,.progress-head>view{display:flex;align-items:center}.progress-head{justify-content:space-between;font-size:23rpx;font-weight:700}.progress-head>text{color:#0f766e}.trend-icon{width:20rpx;height:12rpx;margin-right:10rpx;border-left:3rpx solid #0f766e;border-bottom:3rpx solid #0f766e;transform:skewY(-25deg)}.overall-track{height:18rpx;margin-top:22rpx;overflow:hidden;background:#e5eeff;border-radius:999rpx}.overall-bar{height:100%;background:#005c55;border-radius:999rpx}.progress-foot{display:flex;justify-content:space-between;margin-top:12rpx;color:#64748b;font-size:17rpx}.section-row{display:flex;align-items:center;justify-content:space-between;margin:30rpx 0 18rpx}.section-row>view{display:flex;align-items:center;gap:10rpx;font-size:24rpx;font-weight:700}.section-row>text{padding:5rpx 12rpx;background:#e5eeff;color:#64748b;border-radius:999rpx;font-size:17rpx}.task-list-icon{width:20rpx;height:24rpx;border:2rpx solid #0f766e}.state-card{margin-top:28rpx;background:#fff;border:1rpx solid #e2e8f0;border-radius:20rpx}@keyframes pulse{50%{opacity:.4}}
.task-list-image{width:34rpx;height:34rpx}.task-list-icon{display:none}
