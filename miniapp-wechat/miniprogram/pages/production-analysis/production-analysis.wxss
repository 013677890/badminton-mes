.analysis-page{min-height:100vh;background:#f8fafc;color:#172033}.page-top{height:112rpx;display:flex;align-items:flex-end;gap:14rpx;padding:0 28rpx 20rpx;background:#fff;border-bottom:1rpx solid #e2e8f0;box-sizing:border-box;font-size:29rpx;font-weight:700}.factory-icon{width:25rpx;height:21rpx;border:3rpx solid #0f766e;border-top:0}.refresh-icon{position:relative;width:64rpx;height:64rpx;margin:-10rpx -12rpx -12rpx auto}.refresh-icon:before{content:'';position:absolute;left:19rpx;top:17rpx;width:24rpx;height:24rpx;border:3rpx solid #0f766e;border-left-color:transparent;border-radius:50%}.analysis-content{padding:24rpx 28rpx 150rpx}.periods{display:flex;padding:7rpx;background:#eff4ff;border-radius:18rpx}.period{flex:1;height:64rpx;line-height:64rpx;color:#64748b;text-align:center;border-radius:13rpx;font-size:23rpx}.period--active{background:#0f766e;color:#fff;font-weight:600}.time-range{display:flex;align-items:center;gap:9rpx;margin-top:16rpx;color:#64748b;font-size:19rpx}.clock-icon{width:18rpx;height:18rpx;border:2rpx solid #64748b;border-radius:50%}.compact-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14rpx;margin-top:22rpx}.compact-metric{height:150rpx;display:flex;flex-direction:column;justify-content:space-between;padding:20rpx;background:#fff;border:1rpx solid #e2e8f0;border-radius:18rpx;box-sizing:border-box}.compact-metric text{color:#64748b;font-size:19rpx}.compact-metric view{font-size:30rpx;font-weight:700}.compact-metric small{color:#f97316;font-size:15rpx}.compact-metric--warning view{color:#f97316}.compact-metric--primary{box-shadow:inset 0 0 0 3rpx rgba(15,118,110,.08)}.compact-metric--primary text,.compact-metric--primary view{color:#0f766e;font-weight:700}.defect-card,.trend-card{margin-top:20rpx;padding:26rpx;background:#fff;border:1rpx solid #e2e8f0;border-radius:20rpx}.defect-card{position:relative;display:flex;align-items:center;justify-content:space-between;overflow:hidden}.defect-card text{color:#64748b;font-size:22rpx}.defect-value{margin-top:8rpx;font-size:46rpx;font-weight:800}.defect-value small{padding:5rpx 10rpx;background:#eaf8ee;color:#15803d;border-radius:999rpx;font-size:17rpx}.check-circle{width:72rpx;height:72rpx;display:flex;align-items:center;justify-content:center;background:#eaf8ee;color:#15803d;border-radius:50%;font-size:34rpx}.safe-line{position:absolute;left:26rpx;right:26rpx;bottom:0;padding:16rpx 0;border-top:1rpx dashed #e2e8f0;color:#64748b;font-size:18rpx}.defect-card{padding-bottom:64rpx}.trend-head{display:flex;justify-content:space-between;font-size:23rpx;font-weight:700}.trend-mark{width:20rpx;height:12rpx;border-top:3rpx solid #64748b;transform:skewY(-25deg)}.chart{height:230rpx;display:flex;align-items:flex-end;gap:8rpx;margin-top:25rpx;padding:0 6rpx}.chart-column{flex:1;position:relative;background:#eff4ff;border-radius:3rpx 3rpx 0 0}.chart-column view{position:absolute;left:0;right:0;bottom:0;background:#78b7b3;border-radius:3rpx 3rpx 0 0}.chart-labels{display:flex;justify-content:space-between;margin-top:10rpx;color:#64748b;font-size:14rpx}.state-card{margin-top:24rpx;background:#fff;border:1rpx solid #e2e8f0;border-radius:20rpx}
