.register-page{min-height:100vh;background:#f8fafc;color:#172033}.top-bar{height:112rpx;display:flex;align-items:flex-end;justify-content:space-between;padding:0 20rpx 20rpx;background:#fff;border-bottom:1rpx solid #e2e8f0;box-sizing:border-box;font-size:29rpx;font-weight:700}.back-button,.top-placeholder{width:72rpx;height:64rpx}.back-button{display:flex;align-items:center}.back-arrow{width:18rpx;height:18rpx;margin-left:14rpx;border-left:3rpx solid #172033;border-bottom:3rpx solid #172033;transform:rotate(45deg)}.register-content{padding:42rpx 28rpx}.welcome-title{font-size:40rpx;font-weight:700}.welcome-desc{margin-top:12rpx;color:#64748b;font-size:23rpx;line-height:1.65}.form-card{margin-top:32rpx;padding:30rpx 28rpx;background:#fff;border:1rpx solid #e2e8f0;border-radius:24rpx}.field{margin-bottom:24rpx}.field-label{margin-bottom:12rpx;font-size:24rpx;font-weight:600}.field-label text{margin-left:4rpx;color:#b42318}.input,.picker,.password-shell{height:92rpx;padding:0 22rpx;background:#f8fafc;border:1rpx solid #dbe3eb;border-radius:14rpx;box-sizing:border-box;font-size:25rpx}.input{width:100%}.picker{position:relative;line-height:92rpx}.picker--placeholder{color:#94a3b8}.picker-arrow{position:absolute;right:24rpx;top:34rpx;width:14rpx;height:14rpx;border-right:3rpx solid #64748b;border-bottom:3rpx solid #64748b;transform:rotate(45deg)}.password-shell{display:flex;align-items:center}.password-shell input{flex:1;height:100%}.password-shell view{min-width:72rpx;color:#0f766e;text-align:right;font-size:22rpx}.form-error{margin:-6rpx 0 18rpx;color:#b42318;font-size:22rpx}.register-button{height:92rpx;line-height:92rpx;margin-top:8rpx;background:#0f766e;color:#fff;border-radius:12rpx;font-size:27rpx;font-weight:700}.register-button[disabled]{background:#94a3b8;color:#fff}.register-tip{margin-top:26rpx;padding:20rpx 22rpx;background:#fff7ed;border-radius:12rpx;color:#9a3412;font-size:21rpx;line-height:1.6}
