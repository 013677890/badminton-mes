.account-page{min-height:100vh;background:#f8fafc;color:#172033}.top-bar{height:112rpx;display:flex;align-items:flex-end;justify-content:space-between;padding:0 20rpx 20rpx;background:#fff;border-bottom:1rpx solid #e2e8f0;box-sizing:border-box;font-size:29rpx;font-weight:700}.back,.placeholder{width:72rpx;height:64rpx}.back{display:flex;align-items:center}.back view{width:18rpx;height:18rpx;margin-left:14rpx;border-left:3rpx solid #172033;border-bottom:3rpx solid #172033;transform:rotate(45deg)}.account-main{padding:72rpx 28rpx}.welcome{font-size:40rpx;font-weight:700}.welcome-desc{margin-top:12rpx;color:#64748b;font-size:23rpx}.form-card{margin-top:34rpx;padding:30rpx 28rpx 32rpx;background:#fff;border:1rpx solid #e2e8f0;border-radius:24rpx}.field-label{margin-bottom:12rpx;font-size:24rpx;font-weight:600}.password-label{margin-top:24rpx}.input-shell{height:92rpx;display:flex;align-items:center;padding:0 22rpx;background:#f8fafc;border:1rpx solid #dbe3eb;border-radius:14rpx;box-sizing:border-box}.input-shell input{flex:1;height:100%;margin-left:18rpx;font-size:25rpx}.user-icon{width:27rpx;height:27rpx;border:2rpx solid #64748b;border-radius:5rpx}.lock-icon{position:relative;width:27rpx;height:22rpx;border:2rpx solid #64748b;border-radius:4rpx}.lock-icon:before{content:'';position:absolute;left:5rpx;top:-13rpx;width:13rpx;height:14rpx;border:2rpx solid #64748b;border-bottom:0;border-radius:9rpx 9rpx 0 0}.show{min-width:72rpx;color:#0f766e;text-align:right;font-size:22rpx}.options{display:flex;align-items:center;justify-content:space-between;margin-top:20rpx}.remember{min-height:60rpx;display:flex;align-items:center;gap:12rpx;color:#475569;font-size:22rpx}.checkbox{width:30rpx;height:30rpx;border:2rpx solid #94a3b8;border-radius:6rpx}.checked{position:relative;background:#0f766e;border-color:#0f766e}.checked view{position:absolute;left:8rpx;top:3rpx;width:8rpx;height:14rpx;border-right:3rpx solid #fff;border-bottom:3rpx solid #fff;transform:rotate(45deg)}.register{min-height:60rpx;line-height:60rpx;color:#0f766e;font-size:22rpx;font-weight:600}.error{margin-top:8rpx;color:#b42318;font-size:22rpx}.submit{height:92rpx;line-height:92rpx;margin-top:18rpx;background:#0f766e;color:#fff;border-radius:12rpx;font-size:26rpx;font-weight:700}.submit[disabled]{background:#94a3b8;color:#fff}.security{margin-top:26rpx;color:#94a3b8;text-align:center;font-size:20rpx;line-height:1.6}
.field-icon{width:32rpx;height:32rpx;flex:0 0 32rpx}.user-icon,.lock-icon{display:none}
