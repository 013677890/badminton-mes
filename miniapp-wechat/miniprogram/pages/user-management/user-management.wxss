.manage-page{min-height:100vh;background:#f8fafc;color:#172033}.top-bar{height:calc(44px + 88rpx);display:flex;align-items:center;justify-content:space-between;padding:44px 24rpx 0;background:#fff;border-bottom:1rpx solid #e2e8f0;box-sizing:border-box;font-size:29rpx;font-weight:700}.back,.placeholder{width:72rpx;height:58rpx}.back{display:flex;align-items:center}.back view{width:18rpx;height:18rpx;margin-left:14rpx;border-left:3rpx solid #172033;border-bottom:3rpx solid #172033;transform:rotate(45deg)}.manage-content{padding:24rpx 28rpx 60rpx}.manage-intro{display:flex;align-items:center;margin-bottom:18rpx;padding:20rpx 22rpx;background:linear-gradient(135deg,#0f766e,#115e59);color:#fff;border-radius:20rpx}.manage-intro image{width:52rpx;height:52rpx;margin-right:18rpx;filter:brightness(0) invert(1)}.manage-intro text,.manage-intro small{display:block}.manage-intro text{font-size:25rpx;font-weight:700}.manage-intro small{margin-top:6rpx;color:rgba(255,255,255,.78);font-size:18rpx;line-height:1.5}.search-card,.user-item{background:#fff;border:1rpx solid #e2e8f0;border-radius:20rpx}.search-card{padding:22rpx}.search-row{display:flex;gap:12rpx}.search-row input{flex:1;height:78rpx;padding:0 20rpx;background:#f8fafc;border:1rpx solid #dbe3eb;border-radius:12rpx;box-sizing:border-box;font-size:22rpx}.search-row button{width:130rpx;height:78rpx;line-height:78rpx;background:#0f766e;color:#fff;border-radius:12rpx;font-size:22rpx}.filter-row{display:flex;align-items:center;gap:10rpx;margin-top:16rpx}.filter-row picker{flex:1}.filter-row picker view{height:62rpx;line-height:62rpx;padding:0 14rpx;background:#f8fafc;border-radius:10rpx;color:#475569;font-size:19rpx;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.clear-filter{color:#0f766e;font-size:19rpx;white-space:nowrap}.bind-filters{display:flex;gap:10rpx;margin-top:14rpx}.bind-filters view{padding:10rpx 14rpx;background:#f1f5f9;color:#64748b;border-radius:999rpx;font-size:18rpx}.bind-filters .active{background:#e1f2f0;color:#0f766e;font-weight:600}.user-list{margin-top:20rpx}.user-item{display:flex;align-items:center;margin-bottom:14rpx;padding:22rpx}.avatar{width:70rpx;height:70rpx;line-height:70rpx;flex:0 0 70rpx;background:#eaf5f4;color:#0f766e;border-radius:50%;text-align:center;font-size:27rpx;font-weight:700}.user-copy{flex:1;min-width:0;margin-left:18rpx}.user-copy>view:first-child{display:flex;align-items:center;gap:10rpx;font-size:25rpx;font-weight:700}.user-copy small{padding:4rpx 9rpx;background:#eef9f1;color:#15803d;border-radius:999rpx;font-size:16rpx}.user-copy small.disabled{background:#f1f5f9;color:#64748b}.user-copy>view:nth-child(2),.user-copy>view:nth-child(3){max-width:320rpx;margin-top:7rpx;overflow:hidden;color:#64748b;font-size:19rpx;text-overflow:ellipsis;white-space:nowrap}.user-side{display:flex;align-items:center;gap:14rpx}.bind-state{padding:7rpx 10rpx;background:#fff7ed;color:#c2410c;border-radius:8rpx;font-size:16rpx;white-space:nowrap}.bind-state.bound{background:#eef9f1;color:#15803d}.chevron{width:13rpx;height:13rpx;border-top:2rpx solid #94a3b8;border-right:2rpx solid #94a3b8;transform:rotate(45deg)}.page-state{margin-top:24rpx;padding:60rpx 24rpx;background:#fff;border:1rpx solid #e2e8f0;border-radius:20rpx;color:#64748b;text-align:center}.page-state button{width:200rpx;margin-top:20rpx;background:#0f766e;color:#fff}.load-more{height:74rpx;line-height:74rpx;background:#fff;color:#0f766e;border:1rpx solid #0f766e;border-radius:12rpx;font-size:21rpx}.total{margin-top:18rpx;color:#94a3b8;text-align:center;font-size:18rpx}
