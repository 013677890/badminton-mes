.tab-bar{position:fixed;z-index:500;left:0;right:0;bottom:0;min-height:112rpx;display:flex;align-items:flex-start;justify-content:space-around;padding:8rpx 18rpx calc(10rpx + env(safe-area-inset-bottom));background:#fff;border-top:1rpx solid #e2e8f0;box-sizing:border-box}.tab-item{min-width:112rpx;height:78rpx;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#64748b;border-radius:18rpx;font-size:20rpx}.tab-item--active{background:#0f766e;color:#fff;font-weight:600}.tab-icon{width:36rpx;height:36rpx;margin-bottom:4rpx}.tab-item--active .tab-icon{filter:brightness(0) invert(1);opacity:1}
