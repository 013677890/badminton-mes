# 本地一键启动无需创建 .env；下面的值是 docker-compose.yml 的可选覆盖项。
# 真实部署请复制为 .env 后替换默认值，.env 已被 .gitignore 忽略。

# Docker Hub 代理前缀。本地网络可直连 Docker Hub 时可改为 docker.io。
MES_DOCKER_MIRROR=docker.m.daocloud.io/library

# 构建阶段依赖镜像：npm 与 Gradle/Maven 不再直连海外仓库。
MES_NPM_REGISTRY=https://registry.npmmirror.com
MES_GRADLE_MAVEN_MIRROR=https://maven.aliyun.com/repository/public

# MySQL root 密码(仅容器初始化与健康检查使用)
MYSQL_ROOT_PASSWORD=change-me-root

# 应用数据库账号(容器初始化时自动创建，授予 badminton_mes 库权限)
MES_DB_USERNAME=mes
MES_DB_PASSWORD=change-me

# 浏览器前端允许来源，多个来源使用英文逗号分隔
MES_CORS_ALLOWED_ORIGINS=http://localhost:5173

# 微信小程序登录配置，真实密钥只允许写入本地 .env 或部署环境
MES_WECHAT_MINI_APP_ID=your-mini-app-id
MES_WECHAT_MINI_APP_SECRET=your-mini-app-secret
# 本地联调生成开发版官方小程序码；生产部署应显式设置为 release。
MES_WECHAT_CODE_ENV_VERSION=develop
# Clash Fake-IP/TUN + Docker Desktop 本地开发配置；生产环境通常留空并直连微信。
MES_WECHAT_PROXY_HOST=host.docker.internal
MES_WECHAT_PROXY_PORT=17897
