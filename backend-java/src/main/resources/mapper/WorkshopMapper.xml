<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.badminton.mes.module.production.dal.mapper.WorkshopMapper">

    <!-- 显式 resultMap，不依赖自动映射(ORM-003)；仅映射工单业务用到的列(ORM-001) -->
    <resultMap id="WorkshopResultMap" type="com.badminton.mes.module.production.dal.dataobject.WorkshopDO">
        <id column="id" property="id"/>
        <result column="workshop_code" property="workshopCode"/>
        <result column="workshop_name" property="workshopName"/>
        <result column="status" property="status"/>
    </resultMap>

    <!-- 状态过滤放在 Service 层判断，便于区分"不存在"与"已停用"给出不同提示 -->
    <select id="selectById" resultMap="WorkshopResultMap">
        SELECT id, workshop_code, workshop_name, status
        FROM base_workshop
        WHERE id = #{id} AND is_deleted = 0
    </select>
</mapper>
