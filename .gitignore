# Java / Spring Boot / Maven / Gradle 构建产物
# ==============================================================================

target/
build/
bin/
*.class
*.jar
*.war
*.ear
*.nar

# 保留构建工具 Wrapper，保证不同机器构建版本一致。
!.mvn/wrapper/maven-wrapper.jar
!gradle/wrapper/gradle-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.jar

.mvn/timing.properties
.mvn/wrapper/maven-wrapper.properties.bak
.gradle/
gradle-app.setting

# JVM 崩溃、诊断与临时文件。
hs_err_pid*
replay_pid*
*.hprof
*.jfr

